{
  "name": "pix3",
  "private": true,
  "version": "0.8.8",
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "prebuild": "node scripts/update-version.mjs",
    "dev": "vite",
    "dev:collab": "concurrently \"npm run dev:collab:server\" \"npm run dev\"",
    "dev:collab:server": "npm run dev -w packages/pix3-collab-server",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "format": "prettier --write src/**/*.{ts,css}",
    "format:check": "prettier --check src/**/*.{ts,css}",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/esbuild-wasm/esbuild.wasm', 'public/esbuild.wasm')\""
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@hocuspocus/provider": "^2.15.0",
    "esbuild-wasm": "^0.24.0",
    "feather-icons": "^4.29.2",
    "golden-layout": "^2.6.0",
    "lit": "^3.3.1",
    "monaco-editor": "^0.55.1",
    "reflect-metadata": "^0.2.2",
    "three": "^0.183.2",
    "valtio": "^2.1.8",
    "y-indexeddb": "^9.0.12",
    "yaml": "^2.6.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@eslint/eslintrc": "^3.3.1",
    "@types/feather-icons": "^4.29.4",
    "@types/node": "^24.5.2",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^20.7.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "vite": "^7.1.7",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.0.18"
  },
  "overrides": {},
  "workspaces": [
    "packages/pix3-collab-server"
  ]
}
