# Demo 07 — Cutscene Director (scene.cutscene.playCinematic)
#
# Enter play mode: after a short establishing beat the intro CINEMATIC plays.
# The user:CutsceneTrigger script calls `scene.cutscene.playCinematic('Stage',
# { skippableAfter: 1.5, blendDuration: 0.8 })`, which:
#   • slides in LETTERBOX bars,
#   • LOCKS gameplay input,
#   • plays the 'intro' clip on this node's core:AnimationPlayer — the clip
#     raises "VCam Cinematic"'s priority so the core:CameraBrain BLENDS from the
#     gameplay camera to the cinematic one (director override: 0.8s), dollies the
#     cinematic camera in an arc, levitates + spins the Hero, and fires a "beat"
#     event near the end that punch-scales the Hero (core:PunchScale),
#   • when the clip ends it drops the cinematic priority so the brain blends back
#     to the gameplay camera (director override again: 0.8s).
#
# SKIP: after 1.5s press Esc / Space / Enter (or tap the viewport). The director
# fast-forwards the clip so the end "beat" STILL fires (state-changing beats are
# not dropped), then blends back. REPLAY: once it ends, tap the viewport.
version: 1.0.0
metadata:
  author: Pix3 Demos
  created: 2026-07-11
  description: Cutscene Director — letterbox + input lock + skippable clip + CameraBrain blend, driven from a script.
root:
  - id: stage-root
    type: Node3D
    name: Stage
    properties:
      transform:
        position: [0, 0, 0]
        rotationEuler: [0, 0, 0]
        scale: [1, 1, 1]
    components:
      - id: cinematic-clip
        type: core:AnimationPlayer
        enabled: true
        config:
          # Empty autoplay: the Cutscene Director calls play() explicitly.
          autoplay: ""
          speed: 1
          animations:
            version: "1.0.0"
            clips:
              - name: intro
                duration: 5
                loop: false
                tracks:
                  # Raise the cinematic vcam above the gameplay vcam (priority 20)
                  # for the whole clip, then drop it back at the end. `step` holds
                  # the value so the cut happens cleanly at t=0 and t=5 (the exact
                  # finish), letting the director's blend override smooth both cuts.
                  - id: track-cine-priority
                    kind: property
                    targetPath: VCam Cinematic
                    property: priority
                    valueType: number
                    enabled: true
                    keys:
                      - { time: 0, value: 40, easing: step }
                      - { time: 5, value: 5, easing: step }
                  # Hero levitates up and settles back.
                  - id: track-hero-rise
                    kind: property
                    targetPath: Hero
                    property: position
                    valueType: vector3
                    enabled: true
                    keys:
                      - { time: 0, value: [0, 0.9, 0], easing: sineInOut }
                      - { time: 2.5, value: [0, 3.0, 0], easing: sineInOut }
                      - { time: 5, value: [0, 0.9, 0], easing: sineInOut }
                  # Hero spins a full turn.
                  - id: track-hero-spin
                    kind: property
                    targetPath: Hero
                    property: rotation
                    valueType: euler
                    enabled: true
                    keys:
                      - { time: 0, value: [0, 0, 0], easing: linear }
                      - { time: 5, value: [0, 360, 0], easing: linear }
                  # Cinematic camera arcs laterally in front of the hero (lookAt
                  # keeps it aimed), for a slow dolly-around feel.
                  - id: track-cine-dolly
                    kind: property
                    targetPath: VCam Cinematic
                    property: position
                    valueType: vector3
                    enabled: true
                    keys:
                      - { time: 0, value: [6, 1.2, 6], easing: sineInOut }
                      - { time: 5, value: [-6, 2.2, 6], easing: sineInOut }
                  # The "beat": a state-changing gameplay event near the end. It
                  # fires the Hero's core:PunchScale — and if you SKIP before 4.6s
                  # the director still fires it (fireSkippedEvents, default true).
                  - id: track-beat
                    kind: event
                    name: Beats
                    targetPath: Hero
                    enabled: true
                    keys:
                      - { time: 4.6, signal: beat, args: "" }
      - id: cutscene-trigger
        type: user:CutsceneTrigger
        enabled: true
        config:
          target: ""
          clip: intro
          skippableAfter: 1.5
          blendDuration: 0.8
          autoStart: true
          startDelay: 0.6
          replayOnTap: true
    children:
      - id: render-camera
        type: Camera3D
        name: Render Camera
        properties:
          projection: perspective
          fov: 50
          near: 0.1
          far: 1000
          transform:
            position: [0, 3.5, 11]
            rotationEuler: [-12, 0, 0]
            scale: [1, 1, 1]
        components:
          - id: brain
            type: core:CameraBrain
            enabled: true
        children: []
      - id: key-light
        type: DirectionalLightNode
        name: Key Light
        properties:
          intensity: 2.2
          color: "#ffffff"
          castShadow: true
          shadowCameraSize: 26
          shadowMapSize: 2048
          transform:
            position: [8, 14, 10]
            rotationEuler: [-50, 30, 0]
            scale: [1, 1, 1]
        children: []
      - id: sky-fill
        type: HemisphereLightNode
        name: Sky Fill
        properties:
          skyColor: "#cfe4ff"
          groundColor: "#2a241c"
          intensity: 0.65
          transform:
            position: [0, 6, 0]
            rotationEuler: [0, 0, 0]
            scale: [1, 1, 1]
        children: []
      - id: ground
        type: GeometryMesh
        name: Ground
        properties:
          geometry: plane
          size: [50, 1, 50]
          material:
            type: standard
            color: "#23262e"
            roughness: 1.0
            metalness: 0.0
          transform:
            position: [0, 0, 0]
            rotationEuler: [0, 0, 0]
            scale: [1, 1, 1]
        children: []
      - id: hero
        type: GeometryMesh
        name: Hero
        properties:
          geometry: sphere
          size: [1.5, 1.5, 1.5]
          material:
            type: standard
            color: "#ffcf33"
            roughness: 0.3
            metalness: 0.5
          transform:
            position: [0, 0.9, 0]
            rotationEuler: [0, 0, 0]
            scale: [1, 1, 1]
        components:
          - id: hero-punch
            type: core:PunchScale
            enabled: true
            config:
              amount: 0.5
              duration: 0.5
              vibrato: 4
              triggerEvent: beat
              playOnStart: false
        children: []
      - id: pillar-a
        type: GeometryMesh
        name: Pillar A
        properties:
          geometry: cylinder
          size: [1, 4, 1]
          material:
            type: standard
            color: "#5b6472"
            roughness: 0.8
            metalness: 0.1
          transform:
            position: [-7, 2, -5]
            rotationEuler: [0, 0, 0]
            scale: [1, 1, 1]
        children: []
      - id: pillar-b
        type: GeometryMesh
        name: Pillar B
        properties:
          geometry: cylinder
          size: [1, 4, 1]
          material:
            type: standard
            color: "#5b6472"
            roughness: 0.8
            metalness: 0.1
          transform:
            position: [7, 2, -5]
            rotationEuler: [0, 0, 0]
            scale: [1, 1, 1]
        children: []
      - id: vcam-gameplay
        type: VirtualCamera3D
        name: VCam Gameplay
        properties:
          priority: 20
          fov: 50
          followTargetId: hero
          followOffset: [0, 3.5, 11]
          followDamping: 4
          deadzone: [0.3, 0.3, 0.3]
          lookAtTargetId: hero
          lookAtWeight: 1
          rotationDamping: 6
          blendDuration: 1.0
          blendEasing: cubicInOut
          transform:
            position: [0, 3.5, 11]
            rotationEuler: [-12, 0, 0]
            scale: [1, 1, 1]
        children: []
      - id: vcam-cinematic
        type: VirtualCamera3D
        name: VCam Cinematic
        properties:
          priority: 5
          fov: 38
          followTargetId: ""
          lookAtTargetId: hero
          lookAtWeight: 1
          rotationDamping: 8
          blendDuration: 1.0
          blendEasing: cubicInOut
          transform:
            position: [6, 1.2, 6]
            rotationEuler: [0, 45, 0]
            scale: [1, 1, 1]
        children: []
