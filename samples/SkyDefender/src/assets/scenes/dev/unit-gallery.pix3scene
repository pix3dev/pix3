# Unit Gallery — DEV scene. Every enemy unit prefab laid out in a grid for
# visual review in the editor (no play mode needed). Labels inside the prefabs
# are editorOnly nodes: the runtime strips them from play clones and exports.
version: 1.0.0
metadata:
  author: Sky Defender Remaster
  description: "DEV: all unit prefabs on one scene"
root:
  - id: gallery
    type: Group2D
    name: Unit Gallery
    properties:
      width: 1000
      height: 1000
      transform:
        position: [0, 0]
        scale: [1, 1]
        rotation: 0
    children:
      - id: gal-lucky
        instance: res://src/assets/prefabs/units/lucky.pix3scene
        name: "Lucky"
        properties:
